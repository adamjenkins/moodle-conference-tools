        {
            "title": "<span lang=\"en\" class=\"multilang\">Custom fields</span><span lang=\"ja\" class=\"multilang\">カスタムフィールド</span>",
            "content": "<p><span lang=\"en\" class=\"multilang\">Beyond title and abstract, add your own questions for presenters — affiliation, intended audience, equipment needed, and so on.</span><span lang=\"ja\" class=\"multilang\">タイトルと概要に加えて、応募者に尋ねる独自の質問（所属、対象者、必要な機材など）を追加できます。</span></p>",
            "contentformat": "1",
            "targettype": "2",
            "targetvalue": "",
            "sortorder": "0",
            "configdata": "{\"placement\":\"bottom\",\"backdrop\":true}",
            "files": []
        },
        {
            "title": "<span lang=\"en\" class=\"multilang\">Choose a field type</span><span lang=\"ja\" class=\"multilang\">フィールドタイプを選ぶ</span>",
            "content": "<p><span lang=\"en\" class=\"multilang\">Pick short or long text, a dropdown, checkbox, date, number, or URL to match the answer you want. A dropdown keeps answers consistent for later filtering.</span><span lang=\"ja\" class=\"multilang\">求める回答に合わせて、短文・長文・ドロップダウン・チェックボックス・日付・数値・URL から選びます。ドロップダウンにすると回答が揃い、後で絞り込みやすくなります。</span></p>",
            "contentformat": "1",
            "targettype": "0",
            "targetvalue": "#id_type",
            "sortorder": "1",
            "configdata": "{\"placement\":\"bottom\",\"backdrop\":true}",
            "files": []
        },
        {
            "title": "<span lang=\"en\" class=\"multilang\">Label and required</span><span lang=\"ja\" class=\"multilang\">ラベルと必須設定</span>",
            "content": "<p><span lang=\"en\" class=\"multilang\">The field name is the question label presenters see. You can also make any field required.</span><span lang=\"ja\" class=\"multilang\">フィールド名は、応募者に表示される質問のラベルです。任意のフィールドを必須にすることもできます。</span></p>",
            "contentformat": "1",
            "targettype": "0",
            "targetvalue": "#id_name",
            "sortorder": "2",
            "configdata": "{\"placement\":\"bottom\",\"backdrop\":true}",
            "files": []
        }
